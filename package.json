{
  "name": "scrum-agent",
  "version": "2.0.0",
  "description": "AI-augmented Scrum Master agent — TypeScript + Mastra bot layer, Python AI pipeline",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot.js",
    "dev": "tsx watch src/bot.ts",
    "pipeline": "python pipeline/api.py",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:python": "pytest tests/python -v"
  },
  "dependencies": {
    "@ai-sdk/groq": "^1.0.0",
    "@libsql/client": "^0.17.2",
    "@mastra/core": "^0.10.0",
    "@mastra/libsql": "^0.10.0",
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
