# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id

# ── Discord Channels (IDs) ────────────────────────────────────────────────────
CHANNEL_SPRINT_DISCUSS=0
CHANNEL_STANDUP=0
CHANNEL_TASKS=0
CHANNEL_BLOCKERS=0
CHANNEL_AI_REPORT=0
CHANNEL_CHANGELOG=0

# ── LLM (Python pipeline) ─────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key  # uncomment when switching to Claude

# ── Python Pipeline Bridge ────────────────────────────────────────────────────
PIPELINE_API_URL=http://localhost:8000

# ── Jira / iTrack ─────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SCRUM

# ── Scheduling ────────────────────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata
DAILY_DIGEST_HOUR=9
WEEKLY_REPORT_DAY=friday
WEEKLY_REPORT_HOUR=18

# ── Mastra / SQLite state ─────────────────────────────────────────────────────
# LibSQL file path (relative to project root)
LIBSQL_URL=file:./state/scrum.db

# ── Git / Team log ────────────────────────────────────────────────────────────
TEAM_LOG_REPO_PATH=.
